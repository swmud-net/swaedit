<assembly>
	<id>${assembly.id.win32}</id>
	<formats>
		<format>zip</format>
	</formats>
	<baseDirectory>${assembly.finalName}-${assembly.id.win32}</baseDirectory>
	<componentDescriptors>
		<componentDescriptor>src/main/assembly/bin-main.xml
		</componentDescriptor>
		<componentDescriptor>src/main/assembly/bin-win.xml
		</componentDescriptor>
	</componentDescriptors>
	<fileSets>
		<fileSet>
			<directory>
				${project.build.directory}/dependency/${qtjambi.lib.win32}
			</directory>
			<includes>
				<include>lib/**</include>
			</includes>
			<outputDirectory />
		</fileSet>
		<fileSet>
			<directory>
				${project.build.directory}/dependency/${jogl.lib.win32}
			</directory>
			<includes>
				<include>lib/**</include>
			</includes>
			<outputDirectory />
		</fileSet>
	</fileSets>
</assembly>